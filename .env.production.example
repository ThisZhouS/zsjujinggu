# ===== 掘金股生产部署配置 =====
NODE_ENV=production

# 对外 Web 端口；如使用 Nginx 反代，可保持 3000 并由 Nginx 转发。
WEB_PORT=3000
NEXT_PUBLIC_APP_NAME=掘金股

# Database
POSTGRES_USER=king
POSTGRES_PASSWORD=change-this-strong-db-password
POSTGRES_DB=king
DATABASE_URL=postgresql://king:change-this-strong-db-password@postgres:5432/king

# Redis 由 docker-compose.prod.yml 内部生成 REDIS_URL，默认不暴露公网端口。
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=change-this-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d

# CORS；如果只通过前端访问，可配置为正式域名，例如 https://example.com
CORS_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://server:4000

# mairuiapi
MAIRUI_API_KEY=replace-with-real-mairui-key
MAIRUI_API_BASE=http://api.mairuiapi.com
MAIRUI_API_REALTIME_BASE=http://a.mairuiapi.com
BUSINESS_DATA_MIN_REFRESH_COVERAGE=0.8
BUSINESS_DATA_MIN_TARGET_DATE_COVERAGE=0
BUSINESS_DATA_BLOCK_EMPTY_EXECUTIVE_TRADES=false
TRADINGKEY_MIN_LIST_COMPLETENESS=0.95
TRADINGKEY_BLOCK_EMPTY_DAILY_TRADES=false

# News Automation
NEWS_AUTOMATION_KEY=change-this-news-automation-key

# Email Verification (optional)
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# DeepSeek (optional)
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
# DEEPSEEK_API_KEY=
