DB_CLIENT_ENCODING=GBK
# 鏁版嵁搴撻厤缃?
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=postgres18
DB_USER=postgres
DB_PASSWORD=postgres

# 鏁版嵁搴撹繛鎺ユ睜閰嶇疆
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_ECHO=False
DB_CONNECT_TIMEOUT=10

# API閰嶇疆
API_LICENSE=C149118D-501A-4768-A5F6-C1E6C4087522
API_REQUEST_RATE_LIMIT=60

# 鏃ュ織閰嶇疆
LOG_LEVEL=INFO
LOG_DIR=log

# 失败后重试次数
RETRY_COUNT=3

# 宿主机暴露给 Navicat 等工具的 PG 端口
DB_EXTERNAL_PORT=5433
