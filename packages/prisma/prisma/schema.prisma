// King 财经数据平台 - Prisma Schema
// 包含 20 个数据模型

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户表
model User {
  id            BigInt      @id @default(autoincrement())
  phone         String      @unique
  email         String?     @unique
  emailVerifiedAt DateTime?
  password      String      @db.VarChar(255)
  username      String?     @unique
  nickname      String?
  role          UserRole    @default(USER)
  canUploadArticles Boolean @default(false)
  canAccessVideos  Boolean  @default(false)
  vipExpiresAt  DateTime?
  avatar        String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  favorites     UserFavorite[]
  watchlists    Watchlist[]
  priceAlerts   PriceAlert[]
  notifications Notification[]
  apiKeys       ApiKey[]
  orders        Order[]
  memberLogs    MemberLog[]
  articles      Article[]

  @@map("users")
}

enum UserRole {
  USER
  ADMIN
}

// 牛散表
model Investor {
  id              BigInt   @id @default(autoincrement())
  name            String   @unique @db.VarChar(100)
  avatar          String?
  bio             String?  @db.Text
  totalMarketValue Decimal? @db.Decimal(20, 2)
  stockCount      Int?
  category        String   @default("personal") @db.VarChar(20)
  isTracked       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  holdings        Holding[]
  favorites       UserFavorite[]

  @@index([category, isTracked], map: "idx_investors_category_tracked")
  @@map("investors")
}

// 持仓表
model Holding {
  id          BigInt    @id @default(autoincrement())
  investorId  BigInt
  stockCode   String    @db.VarChar(10)
  stockName   String    @db.VarChar(100)
  holdCount   BigInt
  holdRatio   Decimal?  @db.Decimal(5, 2)
  actualCost  Decimal?  @db.Decimal(20, 2)
  reportDate  DateTime  @db.Date
  dataSlot    BusinessDataSlot @default(PRIMARY)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  investor    Investor  @relation(fields: [investorId], references: [id], onDelete: Cascade)
  stock       Stock     @relation(fields: [stockCode], references: [code], onDelete: Cascade)

  @@unique([investorId, stockCode, reportDate, dataSlot])
  @@index([investorId, dataSlot])
  @@index([stockCode, dataSlot])
  @@index([reportDate, dataSlot])
  @@index([dataSlot, investorId, stockCode, reportDate], map: "idx_holdings_slot_investor_stock_report")
  @@index([dataSlot, reportDate, investorId, stockCode], map: "idx_holdings_slot_report_investor_stock")
  @@map("holdings")
}

// 股票表
model Stock {
  id              BigInt        @id @default(autoincrement())
  code            String        @unique @db.VarChar(10)
  name            String        @db.VarChar(100)
  industry        String?       @db.VarChar(50)
  market          Market        @default(A)
  listingDate     DateTime?     @db.Date
  currentPrice    Decimal?      @db.Decimal(10, 2)
  totalMarketCap  Decimal?      @db.Decimal(20, 2)
  priceUpdatedAt  DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  holdings        Holding[]
  watchlists      Watchlist[]
  dividends       Dividend[]
  klineDailies    KlineDaily[]
  executiveTrades ExecutiveTrade[]

  @@index([code])
  @@index([industry])
  @@map("stocks")
}

enum Market {
  A
  HK
  US
}

enum StarInvestorType {
  BUFFETT
  CATHERINE_WOOD
}

enum StarHoldingChangeType {
  INCREASE
  DECREASE
  KEEP
  UNKNOWN
}

// K线日线表
model KlineDaily {
  id          BigInt   @id @default(autoincrement())
  stockCode   String   @db.VarChar(10)
  tradeDate   DateTime @db.Date
  open        Decimal  @db.Decimal(10, 2)
  high        Decimal  @db.Decimal(10, 2)
  low         Decimal  @db.Decimal(10, 2)
  close       Decimal  @db.Decimal(10, 2)
  volume      BigInt
  amount      Decimal  @db.Decimal(20, 2)
  changePct   Decimal? @db.Decimal(10, 4)
  turnover    Decimal? @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  stock       Stock    @relation(fields: [stockCode], references: [code], onDelete: Cascade)

  @@unique([stockCode, tradeDate])
  @@index([stockCode])
  @@index([tradeDate])
  @@map("kline_daily")
}

model StarInvestorSnapshot {
  id                BigInt           @id @default(autoincrement())
  investorType      StarInvestorType
  investorName      String           @db.VarChar(100)
  organizationName  String?          @db.VarChar(200)
  description       String?          @db.Text
  logoUrl           String?          @db.VarChar(500)
  period            String           @db.VarChar(20)
  reportDate        DateTime?        @db.Date
  holdingStockCount Int?
  holdingValue      Decimal?         @db.Decimal(24, 2)
  tradeProportion   Decimal?         @db.Decimal(14, 8)
  topTenPercent     Decimal?         @db.Decimal(14, 8)
  topIncreaseCode   String?          @db.VarChar(30)
  topIncreaseName   String?          @db.VarChar(100)
  topDecreaseCode   String?          @db.VarChar(30)
  topDecreaseName   String?          @db.VarChar(100)
  sourceUrl         String           @db.VarChar(500)
  scrapedAt         DateTime         @default(now())
  rawPayload        String?          @db.Text
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@unique([investorType, period])
  @@index([investorType, scrapedAt])
  @@map("star_investor_snapshots")
}

model StarInvestorHolding {
  id                      BigInt                @id @default(autoincrement())
  investorType            StarInvestorType
  investorName            String                @db.VarChar(100)
  period                  String                @db.VarChar(20)
  sourceReportDate        DateTime?             @db.Date
  stockCode               String                @db.VarChar(30)
  stockName               String                @db.VarChar(200)
  instrumentCode          String                @default("") @db.VarChar(50)
  iconUrl                 String?               @db.VarChar(500)
  route                   String?               @db.VarChar(200)
  typeRoute               String?               @db.VarChar(50)
  industry                String?               @db.VarChar(100)
  holdingType             StarHoldingChangeType @default(UNKNOWN)
  tradePrice              Decimal?              @db.Decimal(18, 4)
  tradeQuantity           BigInt?
  previousHoldingQuantity BigInt?
  holdingQuantity         BigInt?
  reportDate              DateTime?             @db.Date
  reportMarketValue       Decimal?              @db.Decimal(24, 2)
  changeRate              Decimal?              @db.Decimal(14, 8)
  proportion              Decimal?              @db.Decimal(14, 8)
  latestPrice             Decimal?              @db.Decimal(18, 4)
  latestMarketValue       Decimal?              @db.Decimal(24, 2)
  sourceUrl               String                @db.VarChar(500)
  scrapedAt               DateTime              @default(now())
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  @@unique([investorType, period, stockCode, instrumentCode])
  @@index([investorType, period])
  @@index([investorType, holdingType])
  @@index([stockCode])
  @@map("star_investor_holdings")
}

model StarInvestorTrade {
  id                BigInt                @id @default(autoincrement())
  investorType      StarInvestorType
  investorName      String                @db.VarChar(100)
  period            String                @db.VarChar(20)
  sourceKey         String                @unique @db.VarChar(191)
  sourceReportDate  DateTime?             @db.Date
  stockCode         String                @db.VarChar(30)
  stockName         String                @db.VarChar(200)
  instrumentCode    String                @default("") @db.VarChar(50)
  iconUrl           String?               @db.VarChar(500)
  route             String?               @db.VarChar(200)
  typeRoute         String?               @db.VarChar(50)
  industry          String?               @db.VarChar(100)
  holdingType       StarHoldingChangeType @default(UNKNOWN)
  tradePrice        Decimal?              @db.Decimal(18, 4)
  tradeQuantity     BigInt?
  holdingQuantity   BigInt?
  reportDate        DateTime?             @db.Date
  reportMarketValue Decimal?              @db.Decimal(24, 2)
  changeRate        Decimal?              @db.Decimal(14, 8)
  proportion        Decimal?              @db.Decimal(14, 8)
  latestPrice       Decimal?              @db.Decimal(18, 4)
  sourceUrl         String                @db.VarChar(500)
  scrapedAt         DateTime              @default(now())
  lastSeenAt        DateTime              @default(now())
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([investorType, period])
  @@index([investorType, period, stockCode])
  @@index([reportDate])
  @@map("star_investor_trades")
}

// 文章表
model Article {
  id          BigInt        @id @default(autoincrement())
  title       String        @db.VarChar(200)
  content     String        @db.Text
  summary     String?       @db.VarChar(500)
  coverImage  String?       @db.VarChar(500)
  author      String?       @db.VarChar(50)
  createdByUserId BigInt?
  category    ArticleCategory?
  topicType   ArticleTopicType @default(GENERAL)
  relatedInvestorId BigInt?
  relatedStockCode String?      @db.VarChar(10)
  relatedExecutiveName String?  @db.VarChar(100)
  automationProvider AutomationProvider?
  automationExternalId String?  @db.VarChar(191)
  sourceUrl   String?           @db.VarChar(500)
  sourceMetadata String?        @db.Text
  publishDate DateTime      @default(now())
  isPinned    Boolean       @default(false)
  viewCount   Int           @default(0)
  tags        String[]      @default([])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  createdBy   User?         @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([createdByUserId])
  @@index([category])
  @@index([publishDate])
  @@index([topicType, relatedInvestorId, publishDate], map: "idx_articles_topic_investor_date")
  @@index([topicType, relatedStockCode, publishDate], map: "idx_articles_topic_stock_date")
  @@index([topicType, relatedExecutiveName, publishDate], map: "idx_articles_topic_exec_name_date")
  @@unique([automationProvider, automationExternalId], map: "uq_articles_automation_provider_external")
  @@map("articles")
}

enum ArticleCategory {
  BUFFETT
  WOOD
  GENERAL
}

enum ArticleTopicType {
  GENERAL
  INVESTOR
  EXECUTIVE
}

enum AutomationProvider {
  OPENCLAW
  HARNESS
}

// 高管交易表
model ExecutiveTrade {
  id              BigInt   @id @default(autoincrement())
  stockCode       String   @db.VarChar(10)
  stockName       String   @db.VarChar(100)
  executiveName   String   @db.VarChar(50)
  executivePosition String @db.VarChar(50)
  tradeType       TradeType
  tradeCount      BigInt
  tradePrice      Decimal? @db.Decimal(10, 2)
  tradeAmount     Decimal? @db.Decimal(20, 2)
  tradeDate       DateTime @db.Date
  reportDate      DateTime @db.Date
  dataSlot        BusinessDataSlot @default(PRIMARY)
  createdAt       DateTime @default(now())
  stock           Stock    @relation(fields: [stockCode], references: [code], onDelete: Cascade)

  @@index([stockCode, dataSlot])
  @@index([executiveName, dataSlot])
  @@index([reportDate, dataSlot])
  @@map("executive_trades")
}

enum TradeType {
  INCREASE
  DECREASE
  SAME
}

// 分红表
model Dividend {
  id            BigInt    @id @default(autoincrement())
  stockCode     String    @db.VarChar(10)
  stockName     String    @db.VarChar(100)
  dividendYear  Int
  dividendDate  DateTime? @db.Date
  cashDividend  Decimal?  @db.Decimal(10, 4)
  bonusShare    Decimal?  @db.Decimal(10, 2)
  transferShare Decimal?  @db.Decimal(10, 2)
  totalDividend Decimal?  @db.Decimal(20, 2)
  dividendYield Decimal?  @db.Decimal(10, 4)
  dataSlot      BusinessDataSlot @default(PRIMARY)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  stock         Stock     @relation(fields: [stockCode], references: [code], onDelete: Cascade)

  @@unique([stockCode, dividendYear, dataSlot])
  @@index([dividendYear, dataSlot])
  @@map("dividends")
}

// 用户收藏表
model UserFavorite {
  id          BigInt    @id @default(autoincrement())
  userId      BigInt
  investorId  BigInt
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  investor    Investor  @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@unique([userId, investorId])
  @@index([userId])
  @@map("user_favorites")
}

// 自选股表
model Watchlist {
  id          BigInt   @id @default(autoincrement())
  userId      BigInt
  stockCode   String   @db.VarChar(10)
  stockName   String   @db.VarChar(100)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock       Stock    @relation(fields: [stockCode], references: [code], onDelete: Cascade)

  @@unique([userId, stockCode])
  @@index([userId])
  @@index([stockCode])
  @@map("watchlists")
}

// 价格提醒表
model PriceAlert {
  id          BigInt          @id @default(autoincrement())
  userId      BigInt
  stockCode   String          @db.VarChar(10)
  stockName   String          @db.VarChar(100)
  alertType   PriceAlertType
  targetPrice Decimal         @db.Decimal(10, 2)
  isActive    Boolean         @default( true)
  triggeredAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stockCode])
  @@map("price_alerts")
}

enum PriceAlertType {
  ABOVE
  BELOW
}

// 通知表
model Notification {
  id          BigInt         @id @default(autoincrement())
  userId      BigInt
  type        NotificationType
  title       String         @db.VarChar(200)
  content     String         @db.Text
  isRead      Boolean        @default(false)
  relatedId   BigInt?
  createdAt   DateTime       @default(now())
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

enum NotificationType {
  PRICE_ALERT
  SYSTEM
  VIP_EXPIRED
  ORDER_PAID
  ORDER_REFUNDED
}

// 同步日志表
model SyncLog {
  id          BigInt          @id @default(autoincrement())
  taskName    String          @db.VarChar(50)
  status      SyncStatus
  message     String?         @db.Text
  startTime   DateTime
  endTime     DateTime?
  recordCount Int?
  createdAt   DateTime       @default(now())

  @@index([taskName])
  @@index([status])
  @@index([startTime])
  @@map("sync_logs")
}

enum SyncStatus {
  RUNNING
  SUCCESS
  FAILED
}

enum BusinessDataSlot {
  PRIMARY
  SECONDARY
}

model BusinessDataSourceState {
  id                  Int              @id
  activeSlot          BusinessDataSlot @default(PRIMARY)
  latestFullSyncDate  String?          @db.VarChar(20)
  latestDailySyncDate String?          @db.VarChar(20)
  lastPreparedSlot    BusinessDataSlot?
  lastSwitchAt        DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@map("business_data_source_state")
}

// API Key 表
model ApiKey {
  id          BigInt   @id @default(autoincrement())
  userId      BigInt
  keyHash     String   @unique @db.VarChar(255)
  keyPrefix   String?  @db.VarChar(16)
  plan        ApiPlan  @default(FREE)
  quota       Int      @default(1000)
  used        Int      @default(0)
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageLogs   ApiUsageLog[]

  @@index([userId])
  @@map("api_keys")
}

enum ApiPlan {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

// API 使用日志表
model ApiUsageLog {
  id          BigInt   @id @default(autoincrement())
  apiKeyId    BigInt
  endpoint    String   @db.VarChar(200)
  method      String   @db.VarChar(10)
  statusCode  Int
  responseTime Int
  ip          String?  @db.VarChar(50)
  createdAt   DateTime @default(now())
  apiKey      ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId])
  @@index([createdAt])
  @@map("api_usage_logs")
}

// 订单表
model Order {
  id          BigInt       @id @default(autoincrement())
  orderNo     String       @unique @db.VarChar(50)
  userId      BigInt
  plan        MemberPlan   @default(VIP_MONTHLY)
  amount      Decimal      @db.Decimal(10, 2)
  status      OrderStatus  @default(PENDING)
  paymentType PaymentType
  expiresAt   DateTime
  paidAt      DateTime?
  refundedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([orderNo])
  @@index([status])
  @@map("orders")
}

model PaymentSetting {
  id           BigInt      @id @default(autoincrement())
  paymentType  PaymentType @unique
  qrCodeUrl    String?     @db.VarChar(500)
  accountName  String?     @db.VarChar(100)
  instructions String?     @db.Text
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([isActive])
  @@map("payment_settings")
}

enum OrderStatus {
  PENDING
  PAID
  REFUNDED
  EXPIRED
}

enum PaymentType {
  WECHAT
  ALIPAY
}

enum MemberPlan {
  VIP_MONTHLY
  VIP_YEARLY
  LIFETIME
}

// 会员记录表
model MemberLog {
  id          BigInt        @id @default(autoincrement())
  userId      BigInt
  plan        MemberPlan
  amount      Decimal       @db.Decimal(10, 2)
  startsAt    DateTime
  expiresAt   DateTime
  orderNo     String        @db.VarChar(50)
  createdAt   DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("member_logs")
}

// 广告表
model Ad {
  id          BigInt   @id @default(autoincrement())
  position    AdPosition
  mediaType   AdMediaType @default(IMAGE)
  title       String   @db.VarChar(100)
  content     String   @db.VarChar(500)
  imageUrl    String?  @db.VarChar(500)
  videoUrl    String?  @db.VarChar(500)
  linkUrl     String   @db.VarChar(500)
  isActive    Boolean  @default(true)
  priority    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  adLogs      AdLog[]

  @@index([position])
  @@index([isActive])
  @@map("ads")
}

enum AdMediaType {
  IMAGE
  VIDEO
}

enum AdPosition {
  HOME_TOP
  HOME_VIDEO_HERO
  HOME_SIDEBAR
  ARTICLE_BOTTOM
  MOBILE_BANNER
}

// 广告点击日志表
model AdLog {
  id          BigInt   @id @default(autoincrement())
  adId        BigInt
  userId      BigInt?
  ip          String?  @db.VarChar(50)
  userAgent   String?  @db.VarChar(500)
  createdAt   DateTime @default(now())
  ad          Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@index([adId])
  @@index([createdAt])
  @@map("ad_logs")
}

model Video {
  id          BigInt           @id @default(autoincrement())
  title       String           @db.VarChar(200)
  summary     String?          @db.VarChar(1000)
  description String?          @db.Text
  coverUrl    String?          @db.VarChar(500)
  videoUrl    String           @db.VarChar(500)
  durationSec Int?
  accessLevel VideoAccessLevel @default(PUBLIC)
  isActive    Boolean          @default(true)
  isFeatured  Boolean          @default(false)
  sortOrder   Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([isActive, sortOrder], map: "idx_videos_active_sort")
  @@index([accessLevel, isActive], map: "idx_videos_access_active")
  @@index([isFeatured, isActive], map: "idx_videos_featured_active")
  @@map("videos")
}

enum VideoAccessLevel {
  PUBLIC
  USER
  VIDEO
  VIP
}

// ==================== DataFetch 模块新增模型 ====================

// 公司简介
model CompanyIntro {
  id        BigInt   @id @default(autoincrement())
  stockCode String   @db.VarChar(10)
  name      String   @db.VarChar(100)
  ename     String?  @db.VarChar(200)
  market    String?  @db.VarChar(50)
  idea      String?  @db.Text
  ldate     String?  @db.VarChar(20)
  sprice    String?  @db.VarChar(20)
  principal String?  @db.VarChar(100)
  rdate     String?  @db.VarChar(20)
  rprice    String?  @db.VarChar(20)
  organ     String?  @db.VarChar(100)
  secre     String?  @db.VarChar(50)
  phone     String?  @db.VarChar(20)
  fax       String?  @db.VarChar(20)
  email     String?  @db.VarChar(100)
  site      String?  @db.VarChar(200)
  addr      String?  @db.Text
  desc      String?  @db.Text
  bscope    String?  @db.Text
  pe        String?  @db.VarChar(20)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([stockCode])
  @@index([stockCode])
  @@map("company_intros")
}

// 公司股本
model CompanyCapital {
  id        BigInt   @id @default(autoincrement())
  stockCode String   @db.VarChar(10)
  zgb       Decimal? @db.Decimal(20, 2)  // 总股本
  ysltag    Decimal? @db.Decimal(20, 2)  // 已流通 A 股
  xsltgf    Decimal? @db.Decimal(20, 2)  // 未流通股份
  bdrq      String?  @db.VarChar(20)     // 变动日期
  plrq      String?  @db.VarChar(20)     // 披露日期
  createdAt DateTime @default(now())

  @@index([stockCode])
  @@map("company_capitals")
}

// 解禁限售
model LiftRestriction {
  id        BigInt   @id @default(autoincrement())
  stockCode String   @db.VarChar(10)
  rdate     String?  @db.VarChar(20)     // 解禁日期
  ramount   Decimal? @db.Decimal(20, 2)  // 解禁金额
  rprice    Decimal? @db.Decimal(10, 2)  // 解禁价格
  batch     String?  @db.VarChar(50)     // 批次
  pdate     String?  @db.VarChar(20)     // 公布日期
  createdAt DateTime @default(now())

  @@index([stockCode])
  @@map("lift_restrictions")
}

// 公司股东数
model CompanyShareholderCount {
  id        BigInt   @id @default(autoincrement())
  stockCode String   @db.VarChar(10)
  plrq      String?  @db.VarChar(20)     // 披露日期
  jzrq      String?  @db.VarChar(20)     // 截止日期
  gdzs      Int?     // 股东总数
  agdhs     Int?     // A 股股东户数
  bgdhs     Int?     // B 股股东户数
  hgdhs     Int?     // 港股股东户数
  yltgdhs   Int?     // 无限售条件股东户数
  wltgdhs   Int?     // 有限售条件股东户数
  createdAt DateTime @default(now())

  @@index([stockCode])
  @@map("company_shareholder_counts")
}

// 公司十大股东
model CompanyTopHolders {
  id        BigInt   @id @default(autoincrement())
  stockCode String   @db.VarChar(10)
  plrq      String?  @db.VarChar(20)     // 披露日期
