# 数据库配置
DATABASE_URL="postgresql://king:king123@localhost:5433/king"

# Redis 配置
REDIS_URL="redis://localhost:6379"

# JWT 配置
JWT_SECRET="king-jwt-secret-change-in-production"
JWT_EXPIRES_IN="7d"
CORS_ORIGIN="http://localhost:3000"

# 外部 API 配置
MAIRUI_API_KEY="your-mairui-api-key"
# DeepSeek 可选，不配置不影响 mairui 数据同步和业务页面启动
# DEEPSEEK_API_KEY="your-deepseek-api-key"

# 邮箱验证码配置（建议使用网站所有者提供的 163 邮箱授权码）
SMTP_HOST="smtp.163.com"
SMTP_PORT=465
SMTP_USER="your-site-owner@163.com"
SMTP_PASS="your-163-smtp-authorization-code"
SMTP_FROM="your-site-owner@163.com"

BUSINESS_DATA_MIN_REFRESH_COVERAGE=0.8
BUSINESS_DATA_MIN_TARGET_DATE_COVERAGE=0
BUSINESS_DATA_BLOCK_EMPTY_EXECUTIVE_TRADES=false
TRADINGKEY_MIN_LIST_COMPLETENESS=0.95
TRADINGKEY_BLOCK_EMPTY_DAILY_TRADES=false

# 服务器配置
PORT=4000
