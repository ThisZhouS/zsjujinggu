{
  "name": "king-monorepo",
  "version": "1.0.0",
  "description": "King \u8d22\u7ecf\u6570\u636e\u5e73\u53f0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "cd packages/prisma && pnpm prisma generate",
    "db:migrate": "cd packages/prisma && pnpm prisma migrate dev",
    "db:push": "cd packages/prisma && pnpm prisma db push",
    "db:studio": "cd packages/prisma && pnpm prisma studio"
  },
  "devDependencies": {
    "prettier": "^3.1.1",
    "turbo": "^1.11.2"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "prisma",
      "unrs-resolver"
    ]
  }
}