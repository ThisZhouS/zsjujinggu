# ===== 后端环境变量 =====
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://king:king123@localhost:5433/king

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-random-secret-key-min-32-chars-for-security
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000

# Admin Account
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# mairuiapi
# 迈瑞密钥直接替换为真实 key；代码统一读取 MAIRUI_API_KEY。
MAIRUI_API_KEY=your-mairui-api-key
MAIRUI_API_BASE=http://api.mairuiapi.com
MAIRUI_API_REALTIME_BASE=http://a.mairuiapi.com
BUSINESS_DATA_MIN_REFRESH_COVERAGE=0.8
BUSINESS_DATA_MIN_TARGET_DATE_COVERAGE=0
BUSINESS_DATA_BLOCK_EMPTY_EXECUTIVE_TRADES=false
TRADINGKEY_MIN_LIST_COMPLETENESS=0.95
TRADINGKEY_BLOCK_EMPTY_DAILY_TRADES=false

# DeepSeek（可选，不配置不影响 mairui 数据同步和业务页面启动）
# DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# Email Verification (163 SMTP)
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=your-site-owner@163.com
SMTP_PASS=your-163-smtp-authorization-code
SMTP_FROM=your-site-owner@163.com

# Logging
LOG_LEVEL=info

# News Automation
NEWS_AUTOMATION_KEY=your-news-automation-ingest-key

# ===== 前端环境变量 =====
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=掘金股

